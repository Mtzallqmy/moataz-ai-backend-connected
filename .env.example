# Railway will provide PORT automatically
PORT=8080
NODE_ENV=production

# Put your Vercel frontend domain here after deployment.
# For local development you can use http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Supabase project settings
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# 32+ random characters. Used to encrypt provider keys, Telegram tokens and repository tokens before saving them in Supabase.
APP_ENCRYPTION_KEY=change-this-to-a-long-random-secret

# Optional. Used only when creating Telegram webhooks.
PUBLIC_BACKEND_URL=https://your-backend.up.railway.app
